#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
TEST_RUNNER="$REPO_ROOT/scripts/run-tests.sh"

if [[ ! -f "$TEST_RUNNER" ]]; then
  echo "Error: test runner not found at $TEST_RUNNER"
  exit 1
fi

echo "Running automated tests before commit..."
bash "$TEST_RUNNER"
